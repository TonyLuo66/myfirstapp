{
  "App": {
    "Name": "My First Container App",
    "Environment": "local",
    "Message": "使用 Dapper + SQL Server + Query/Command 的示範服務",
    "RunMode": "once",
    "HeartbeatSeconds": 5
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=myfirstapp;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True",
    "MasterConnection": "Server=(localdb)\\MSSQLLocalDB;Database=master;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Database": {
    "SeedOnStartup": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}